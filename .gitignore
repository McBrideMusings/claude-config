# Blanket-ignore everything by default, then allowlist the three dirs.
# This is safer than a denylist: any new file Claude Code adds is
# ignored unless explicitly unignored below.

*

# Allowlist
!.gitignore
!.gitmodules
!README.md
!agents/
!agents/**
!skills/
!skills/**
!commands/
!commands/**
!settings.json
!statusline-command.sh
!statusline-config.txt
!fetch-claude-usage.swift
